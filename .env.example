# 数据库连接
DATABASE_URL=postgresql://username:password@localhost:5432/aeonstory

# 服务端口
PORT=3001

# JWT密钥（生产环境请使用强密码）
JWT_SECRET=your-secret-key-here

# n8n连接（可选）
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key
N8N_WORKFLOW_ID=your-workflow-id

# YouTube API（可选）
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# 前端环境变量
VITE_APP_TITLE=AeonStory 指挥中心
